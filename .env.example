APP_NAME="Gestão Acesso"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# API do copiloto (Sanctum): gere token com php artisan tinker → $user->createToken('agent')
# Header opcional: X-Operating-Company-Id={id}
#
# --- OpenAI (padrão) ---
# AGENT_LLM_ENABLED=true
# AGENT_LLM_PROVIDER=openai
# AGENT_LLM_API_KEY=sk-...
# AGENT_LLM_MODEL=gpt-4o-mini
#
# --- Groq (Llama 3.3 70B — teste rápido, API OpenAI-compatible) ---
# AGENT_LLM_ENABLED=true
# AGENT_LLM_PROVIDER=groq
# AGENT_LLM_API_KEY=gsk_...
# AGENT_LLM_MODEL=llama-3.3-70b-versatile
# AGENT_LLM_BASE_URL=https://api.groq.com/openai/v1
# AGENT_LLM_TIMEOUT=60
# AGENT_LLM_SUPPORTS_VISION=false
# AGENT_LLM_VERIFY_SSL=false
#   ↑ Windows dev: false evita erro cURL 60 (certificado SSL). Em produção/Linux deixe true.
# AGENT_LLM_DAILY_TOKEN_LIMIT=500000
#
# AGENT_LLM_DAILY_TOKEN_LIMIT= — quota global diária (tokens); sobrescreva por empresa/usuário no cadastro
# AGENT_LLM_E2E=true — habilita testes de integração com LLM real (php artisan test --group=llm-live)
# AGENT_CHAT_REQUIRE_CONFIRMATION=true exige confirmação antes de comandos de escrita (modo Agente)
# AGENT_CHAT_MAX_HISTORY=20 — mensagens user/assistant enviadas ao LLM em conversas multi-turn
# AGENT_TASK_SSE_POLL_MS=1000 — intervalo do stream SSE de tarefas em background
# AGENT_MAX_ATTACHMENTS=3
# AGENT_MAX_ATTACHMENT_KB=10240

# Gateway de cobrança PIX/boleto (Prioridade A — 11.7)
# PAYMENT_GATEWAY_DRIVER=mock
# ASAAS_API_KEY=
# ASAAS_ENVIRONMENT=sandbox
# ASAAS_WEBHOOK_TOKEN=

# Ponte fiscal — registro para emissão no ERP (Prioridade A — 16.x)
# FISCAL_BRIDGE_ENABLED=true
# FISCAL_DEFAULT_ERP=omie
# OMIE_APP_KEY=
# OMIE_APP_SECRET=
# OMIE_NFSE_SERVICE_CODE=1.01

# Exportação contábil (Omie / Bling / Sisloc) — layouts fixos, sem NF-e
# ACCOUNTING_EXPORT_FORMAT=csv
# ACCOUNTING_OMIE_CATEGORIA=1.01.01
# ACCOUNTING_OMIE_CONTA_CORRENTE=1
# ACCOUNTING_BLING_CATEGORIA=Receitas de locação
# ACCOUNTING_BLING_PORTADOR=Caixa
# ACCOUNTING_BLING_FORMA_PAGAMENTO=Transferência
# ACCOUNTING_SISLOC_EMPRESA=1
# ACCOUNTING_SISLOC_TIPO_DOC=LOC

# OPERATIONAL_ALERTS_ENABLED=true
# OPERATIONAL_ALERTS_EXTRA_RECIPIENTS=financeiro@empresa.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# PostgreSQL (produção recomendada)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=linha_leve
DB_USERNAME=postgres
DB_PASSWORD=

# SQLite (desenvolvimento local alternativo)
# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@acesso.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Usuário inicial (criado por php artisan db:seed)
# admin@acesso.local / Acesso@2026

# Manutenção — análise financeira e preventiva automática
MAINTENANCE_HOURLY_RATE=65
MAINTENANCE_AUTO_OPEN_PREVENTIVE=true
MAINTENANCE_PREVENTIVE_MODE=open_when_available
MAINTENANCE_PREVENTIVE_WARNING_HOURS=50

# Cabeçalho dos documentos PDF (Fase 5)
DOCUMENTS_COMPANY_NAME="ACESSO equipamentos"
DOCUMENTS_COMPANY_DOCUMENT=
DOCUMENTS_COMPANY_ADDRESS=
DOCUMENTS_COMPANY_PHONE=
DOCUMENTS_COMPANY_EMAIL=
# Caminho relativo em public/ ou storage/app/
DOCUMENTS_LOGO_PATH=stack/assets/logo.png

# Geocoding — mapa de obras e coordenadas na locação (Nominatim ou Google)
# GEOCODING_ENABLED=true
# GEOCODING_DRIVER=nominatim
# NOMINATIM_USER_AGENT="Gestão Acesso Geocoder (contato@empresa.com)"
# GOOGLE_GEOCODING_API_KEY=
# GEOCODING_CACHE_TTL_DAYS=90

# CRM — pipeline, campanhas e mensagens (Fase 15)
# CRM_MESSAGING_DRIVER=log — log (dev), link (WhatsApp wa.me), twilio (SMS/WhatsApp API)
# CRM_INACTIVE_MONTHS=6
# CRM_FOLLOW_UP_REMINDERS=true
# CRM_DEFAULT_COUNTRY_CODE=55
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SMS_FROM=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
